DB_SOCKET=/var/lib/mysql/mysql.sock
DB_USER=usuario_do_mysql
DB_PASS=senha_do_mysql
DB_NAME=nome_do_banco

REPORT_USER=lemoov
REPORT_PASS=L3moov@

# Pasta persistente para fotos enviadas pelo admin.
# Na Hostinger, use um caminho fora da pasta que o deploy substitui.
# Exemplo: /home/u809548894/domains/lemoov.com.br/public_html/uploads
UPLOAD_DIR=
UPLOAD_PUBLIC_PREFIX=uploads

# Preparado para a etapa de integração real com a InfinityPay.
# Enquanto INFINITYPAY_API_KEY estiver vazio, o checkout usa modo assistido.
INFINITYPAY_API_KEY=
INFINITYPAY_CHECKOUT_BASE=
