DB_SOCKET=/var/lib/mysql/mysql.sock
DB_USER=usuario_do_mysql
DB_PASS=senha_do_mysql
DB_NAME=nome_do_banco

REPORT_USER=lemoov
REPORT_PASS=L3moov@

# Pasta persistente para fotos enviadas pelo admin.
# Padrão automático: pasta "uploads" UM NÍVEL ACIMA do app (fora do nodejs/).
# Isso já persiste entre deploys sem precisar configurar nada.
# Se quiser sobrescrever, defina o caminho absoluto abaixo:
# Exemplo: /home/u809548894/domains/lemoov.com.br/uploads
UPLOAD_DIR=
UPLOAD_PUBLIC_PREFIX=uploads

# Checkout InfinitePay — handle sem o $ do início (InfiniteTag do app).
# Enquanto INFINITEPAY_HANDLE estiver vazio, o checkout usa modo assistido.
SITE_URL=https://lemoov.com.br
INFINITEPAY_HANDLE=lemoovfitnessoficial
INFINITEPAY_API_URL=https://api.checkout.infinitepay.io/links

# Motor de Frete Híbrido (FASE 3)
# Token gerado em: https://melhorenvio.com.br → Configurações → Tokens de Acesso
# Sem este token, o SEDEX usa valor fixo de contingência (R$ 30,00).
MELHOR_ENVIO_TOKEN=

# CEP de origem da loja (padrão: 60360760 — já configurado no código)
# Só precisa definir se o endereço de despacho for diferente.
CEP_ORIGEM=60360760
